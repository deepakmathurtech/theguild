rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================================
    // CORE SECURITY FUNCTIONS
    // ============================================================
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function role() { return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? userDoc().data.role : 'applicant'; }

    // ============================================================
    // PRIVILEGE LEVELS (Hierarchical)
    // ============================================================
    function isFounder() { return signedIn() && (role() == 'guildFounder' || role() == 'founder'); }
    function isCentralMaster() { return isFounder() || role() == 'centralGuildMaster'; }
    function isStateMaster() { return isCentralMaster() || (role() == 'stateGuildMaster'); }
    function isCityMaster() { return isStateMaster() || (role() == 'cityGuildMaster'); }
    function isReceptionist() { return isCityMaster() || role() == 'receptionist'; }
    function isMember() { return signedIn() && role() in ['member', 'contributor', 'receptionist', 'cityGuildMaster', 'stateGuildMaster', 'centralGuildMaster', 'guildFounder', 'founder']; }
    function isOrgRepresentative() { return signedIn() && role() == 'organizationRepresentative'; }

    // ============================================================
    // JURISDICTION FUNCTIONS
    // ============================================================
    function myJuris() { return userDoc().data.jurisdiction; }
    function targetJuris() { return resource.data.jurisdiction; }
    function incomingJuris() { return request.resource.data.jurisdiction; }

    function isSameCity() { return targetJuris().cityId == myJuris().cityId; }
    function isSameState() { return targetJuris().stateId == myJuris().stateId; }
    function isSameCountry() { return targetJuris().countryId == myJuris().countryId; }
    function isInMyJuris() { return isSameCountry() && (isSameState() || isSameCity()); }
    function isBranchScope() { return targetJuris().cityId == myJuris().cityId; }
    function isStateScope() { return targetJuris().stateId == myJuris().stateId; }

    // ============================================================
    // OWNERSHIP & PERMISSION FUNCTIONS
    // ============================================================
    function owns(uid) { return signedIn() && request.auth.uid == uid; }
    function ownsDoc(field) { return signedIn() && request.auth.uid == resource.data[field]; }
    function ownsIncoming(field) { return signedIn() && request.auth.uid == request.resource.data[field]; }
    function isOwnerOrMaster() { return ownsDoc('ownerId') || isReceptionist(); }
    function noPermanentDelete() { return false; }

    // ============================================================
    // ANTI-PRIVILEGE ESCALATION
    // ============================================================
    function cannotSelfUpgrade() {
      return request.auth.uid != resource.data.uid;
    }
    function cannotExceedMyLevel() {
      let newRole = request.resource.data.role;
      let myLevel = getPrivilegeLevel(role());
      let newLevel = getPrivilegeLevel(newRole);
      return newLevel <= myLevel;
    }
    function getPrivilegeLevel(r) {
      return r == 'founder' || r == 'guildFounder' ? 7 :
             r == 'centralGuildMaster' || r == 'nationalGuildMaster' ? 6 :
             r == 'stateGuildMaster' ? 5 :
             r == 'cityGuildMaster' ? 4 :
             r == 'receptionist' ? 3 :
             r == 'contributor' ? 2 :
             r == 'member' ? 1 : 0;
    }

    // ============================================================
    // JURISDICTION PERMISSION CHECKER
    // ============================================================
    function canWriteJuris(data) {
      return isFounder() || (
        data.jurisdiction.countryId == myJuris().countryId &&
        (role() == 'centralGuildMaster' || (
          data.jurisdiction.stateId == myJuris().stateId && (
            role() == 'stateGuildMaster' || (
              data.jurisdiction.cityId == myJuris().cityId && (role() == 'cityGuildMaster' || role() == 'receptionist')
            )
          )
        ))
      );
    }

    // ============================================================
    // QUEST CAPACITY CHECK
    // ============================================================
    function hasQuestCapacity(questData) {
      let currentCount = questData.acceptedMembers.size();
      let required = questData.membersRequired != null ? questData.membersRequired : 1;
      return currentCount < required;
    }

    // ============================================================
    // AUDIT LOGGING PROTECTION
    // ============================================================
    function isAuditLogValid() {
      let data = request.resource.data;
      return data.userId != null && data.action != null && data.time != null;
    }
    function canWriteAudit() {
      return signedIn() && isAuditLogValid();
    }

    // ============================================================
    // DATA VALIDATION
    // ============================================================
    function hasRequiredFields(data, required) {
      return required.all(r => data.keys().hasAll([r]));
    }

    // ============================================================
    // COLLECTION: USERS
    // ============================================================
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if owns(userId) && request.resource.data.keys().hasAll(['email', 'fullName', 'jurisdiction']);
      allow update: if (
        owns(userId) || isReceptionist()
      ) && (
        owns(userId) || cannotSelfUpgrade()
      ) && (
        owns(userId) || cannotExceedMyLevel()
      );
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: ORGANIZATIONS
    // ============================================================
    match /organizations/{id} {
      allow read: if signedIn();
      allow create: if isMember() && canWriteJuris(request.resource.data);
      allow update: if isReceptionist() && canWriteJuris(resource.data) || (
        signedIn() && resource.data.ownerId == request.auth.uid
      );
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: NEEDS
    // ============================================================
    match /needs/{id} {
      allow read: if signedIn();
      allow create: if isMember() && canWriteJuris(request.resource.data);
      allow update: if isReceptionist() && canWriteJuris(resource.data);
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: OPPORTUNITIES
    // ============================================================
    match /opportunities/{id} {
      allow read: if signedIn() && (isBranchScope() || isCentralMaster());
      allow create: if isMember() && canWriteJuris(request.resource.data);
      allow update: if signedIn() && (
        canWriteJuris(resource.data) ||
        incomingJuris().applicants.hasAny([request.auth.uid])
      );
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: QUESTS
    // ============================================================
    match /quests/{id} {
      allow read: if signedIn();
      allow create: if isMember() && canWriteJuris(request.resource.data);
      allow update: if isReceptionist() && canWriteJuris(resource.data) || (
        // Quest lead can update their quest
        signedIn() && resource.data.ownerId == request.auth.uid
      );
      // Capacity enforcement - prevent over-assignment
      allow update: if !hasQuestCapacity(resource.data) && request.resource.data.acceptedMembers != resource.data.acceptedMembers
        ? false
        : true;
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: QUEST APPLICATIONS
    // ============================================================
    match /questApplications/{id} {
      allow read: if signedIn() && (
        resource.data.applicantId == request.auth.uid ||
        isReceptionist()
      );
      allow create: if signedIn() && request.resource.data.applicantId == request.auth.uid;
      // Applicants can only update their own draft applications
      allow update: if signedIn() && (
        resource.data.applicantId == request.auth.uid && resource.data.status == 'draft'
      ) || isReceptionist();
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: QUEST PARTICIPATIONS
    // ============================================================
    match /questParticipations/{id} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        isReceptionist()
      );
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isReceptionist() || (
        signedIn() && resource.data.userId == request.auth.uid
      );
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: QUEST SUBMISSIONS
    // ============================================================
    match /questSubmissions/{id} {
      allow read: if signedIn() && (
        resource.data.memberId == request.auth.uid ||
        isReceptionist()
      );
      allow create: if signedIn() && request.resource.data.memberId == request.auth.uid;
      allow update: if isReceptionist() || (
        signedIn() && resource.data.memberId == request.auth.uid && resource.data.status == 'pending'
      );
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: OUTCOMES
    // ============================================================
    match /outcomes/{id} {
      allow read: if signedIn();
      allow create, update: if isMember() && canWriteJuris(request.resource.data);
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: VERIFICATIONS
    // ============================================================
    match /verifications/{id} {
      allow read: if isReceptionist();
      allow create, update: if isReceptionist();
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: REVENUE EVENTS
    // ============================================================
    match /revenueEvents/{id} {
      allow read: if isReceptionist();
      allow create: if isReceptionist();
      allow update: if isReceptionist();
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: PAYMENTS (NEW)
    // ============================================================
    match /payments/{id} {
      allow read: if signedIn() && (
        resource.data.payerId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid ||
        isReceptionist()
      );
      allow create: if signedIn() && request.resource.data.payerId == request.auth.uid;
      allow update: if isReceptionist() || (
        signedIn() && resource.data.payerId == request.auth.uid && resource.data.status == 'pending'
      );
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: RECEIPTS (NEW)
    // ============================================================
    match /receipts/{id} {
      allow read: if signedIn();
      allow create: if isReceptionist();
      allow update: if isReceptionist();
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: KNOWLEDGE BASE
    // ============================================================
    match /knowledgeBase/{id} {
      allow read: if signedIn();
      allow create: if isMember();
      allow update: if isReceptionist();
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: ACTIVITY LOGS
    // ============================================================
    match /activityLogs/{id} {
      allow read: if isCityMaster();
      allow create: if canWriteAudit();
      allow update, delete: if false;
    }

    // ============================================================
    // COLLECTION: NOTIFICATIONS
    // ============================================================
    match /notifications/{id} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        isReceptionist()
      );
      allow create: if isReceptionist();
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: GUILD REGIONS
    // ============================================================
    match /guildRegions/{id} {
      allow read: if signedIn();
      allow write: if isFounder();
    }

    // ============================================================
    // COLLECTION: GUILD STATES
    // ============================================================
    match /guildStates/{id} {
      allow read: if signedIn();
      allow create: if isCentralMaster();
      allow update: if isCentralMaster();
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: GUILD CITIES
    // ============================================================
    match /guildCities/{id} {
      allow read: if signedIn();
      allow create, update: if isStateMaster();
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: BRANCHES
    // ============================================================
    match /branches/{id} {
      allow read: if signedIn();
      allow create: if isCityMaster();
      allow update: if isCityMaster();
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: SUCCESSION PLANS
    // ============================================================
    match /successionPlans/{id} {
      allow read: if isReceptionist();
      allow write: if isFounder();
    }

    // ============================================================
    // COLLECTION: LEAVE RECORDS
    // ============================================================
    match /leaveRecords/{id} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        isReceptionist()
      );
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isReceptionist();
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: ESCALATION RECORDS
    // ============================================================
    match /escalationRecords/{id} {
      allow read: if isCityMaster();
      allow create: if signedIn();
      allow update: if isReceptionist();
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: DISPUTE RECORDS
    // ============================================================
    match /disputeRecords/{id} {
      allow read: if isReceptionist();
      allow create: if signedIn();
      allow update: if isReceptionist();
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: TRANSFER RECORDS
    // ============================================================
    match /transferRecords/{id} {
      allow read: if isCityMaster();
      allow create, update: if isFounder();
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: RANK REVIEWS
    // ============================================================
    match /rankReviews/{id} {
      allow read: if signedIn() && (
        resource.data.memberId == request.auth.uid ||
        isReceptionist()
      );
      allow create: if signedIn() && request.resource.data.memberId == request.auth.uid;
      allow update: if isReceptionist();
      allow delete: if noPermanentDelete();
    }

    // ============================================================
    // COLLECTION: ORGANIZATION ACTIVITIES (NEW)
    // ============================================================
    match /organizationActivities/{id} {
      allow read: if signedIn();
      allow create: if isMember() && canWriteJuris(request.resource.data);
      allow update: if isReceptionist();
      allow delete: if noPermanentDelete();
    }
  }
}